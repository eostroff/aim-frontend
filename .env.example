# AIM Dashboard — Environment Configuration
# ==========================================
# Copy this file to .env and adjust values for your deployment.
# .env is gitignored and should never be committed.

# ── CAN Bus ───────────────────────────────────────────────────────────────────
# SocketCAN interface name as shown by `ip link`.
AIM_CAN_CHANNEL=can0

# CAN bus bitrate in bits per second. Must match the STM32 configuration.
AIM_CAN_BITRATE=500000

# ── Database ──────────────────────────────────────────────────────────────────
# Absolute or relative path to the SQLite database file.
# Defaults to inventory.db in the project root.
AIM_DB_PATH=inventory.db

# ── Flask ─────────────────────────────────────────────────────────────────────
# Port the dashboard web server listens on.
AIM_FLASK_PORT=3000

# ── Logging ───────────────────────────────────────────────────────────────────
# Path to the log file. Parent directory is created automatically if missing.
AIM_LOG_PATH=logs/aim.log

# Minimum log level written to both console and file.
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
AIM_LOG_LEVEL=INFO

# Maximum size of a single log file in bytes before it rotates.
AIM_LOG_MAX_BYTES=1000000

# Number of rotated log files to keep alongside the active one.
AIM_LOG_BACKUP_COUNT=3
